{
  "expo": {
    "name": "RecipeSocial",
    "slug": "recipesocial",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.recipesocial",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yourname.recipesocial",
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow RecipeSocial to access your photos to upload recipe images.",
          "cameraPermission": "Allow RecipeSocial to use your camera."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow RecipeSocial to access your camera for AI ingredient scanning."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow RecipeSocial to access your microphone to record recipe instructions."
        }
      ],
      "expo-secure-store",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "0c407f94-98f9-4f18-8d56-81ff1fb53604"
      }
    }
  }
}
